        <mxCell id="v7wYzxMNztZIk_eU5v4j-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontFamily=Comic Sans MS;fontSize=13;" value="&lt;font style=&quot;font-size: 17px;&quot;&gt;Merchant&lt;/font&gt;" vertex="1">
          <mxGeometry height="120" width="120" x="80" y="260" as="geometry" />
        </mxCell>
        <mxCell id="v7wYzxMNztZIk_eU5v4j-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontFamily=Comic Sans MS;fontSize=13;" value="&lt;font style=&quot;font-size: 17px;&quot;&gt;API GATEWAY&lt;br&gt;&lt;br&gt;Authentication&lt;/font&gt;" vertex="1">
          <mxGeometry height="300" width="140" x="300" y="170" as="geometry" />
        </mxCell>
        <mxCell id="v7wYzxMNztZIk_eU5v4j-5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontFamily=Comic Sans MS;fontSize=13;" value="&lt;font&gt;&lt;u style=&quot;&quot;&gt;FUNCTIONAL REQUIREMENTS&lt;/u&gt;&lt;/font&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;1. Merchants should be able to initiate payments.&lt;/div&gt;&lt;div&gt;2. Users should be able to pay via Debit/credit cards.&lt;/div&gt;&lt;div&gt;3. Merchants should be able to view the status of the payments.&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="410" x="-530" y="110" as="geometry" />
        </mxCell>
        <mxCell id="v7wYzxMNztZIk_eU5v4j-6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;fontFamily=Comic Sans MS;fontSize=13;" value="&lt;u&gt;&lt;font&gt;NON-FUNTIONAL REQUIREMENTS&lt;/font&gt;&lt;br&gt;&lt;/u&gt;&lt;br&gt;&lt;div&gt;1. Scale to 10TPS.&lt;/div&gt;&lt;div&gt;2. System should be highly secure.&lt;/div&gt;&lt;div&gt;3. Strong durability (no transaction loss)&lt;/div&gt;&lt;div&gt;4.Transaction safety and financial integrity(no double charge)&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="410" x="-530" y="240" as="geometry" />
        </mxCell>
        <mxCell id="v7wYzxMNztZIk_eU5v4j-7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Comic Sans MS;fontStyle=1;fontSize=13;" value="&lt;u&gt;&lt;font&gt;&lt;span&gt;CORE ENTITIES&lt;br&gt;&lt;/span&gt;&lt;/font&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/u&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;1. Merchant: Info about the business&lt;br&gt;2. Payment Intent: Purpose of payment and status of the payment.&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;&lt;font&gt;3. Transactions: Actual transaction linked to one Payment Intent(Charge, Refund, Dispute)&lt;br&gt;&lt;/font&gt;- &lt;font style=&quot;&quot;&gt;Amount, currency, status, timestamp, paymentIntentId, merchantId&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="420" x="-530" y="380" as="geometry" />
        </mxCell>
        <mxCell id="v7wYzxMNztZIk_eU5v4j-9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Comic Sans MS;fontStyle=1;fontSize=13;" value="&lt;div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;font style=&quot;font-size: 15px;&quot;&gt;&lt;div style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &lt;u style=&quot;&quot;&gt;&lt;font&gt;API&lt;/font&gt;&lt;/u&gt;&lt;br&gt;&lt;br&gt;POST /payment-intents -&amp;gt; paymentIntentId&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;{&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; &quot;amountInCents&quot;: 2499,&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; &quot;currency&quot;: &quot;usd&quot;,&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; &quot;description&quot;: &quot;Order #1234&quot;,&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;}&lt;br&gt;&lt;br&gt;&lt;/div&gt;&lt;br&gt;&lt;div style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;POST /payment-intents/{paymentIntentId}/transactions&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;{&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; &quot;type&quot;: &quot;charge&quot;,&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; &quot;card&quot;: {&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; &amp;nbsp; &quot;number&quot;: &quot;4242424242424242&quot;,&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; &amp;nbsp; &quot;exp_month&quot;: 12,&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; &amp;nbsp; &quot;exp_year&quot;: 2025,&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; &amp;nbsp; &quot;cvc&quot;: &quot;123&quot;&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&amp;nbsp; }&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;}&lt;/div&gt;&lt;div style=&quot;color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span&gt;GET /payment-intents/{paymentIntentId} -&amp;gt; PaymentIntent&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;/font&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="430" width="450" x="-560" y="590" as="geometry" />
