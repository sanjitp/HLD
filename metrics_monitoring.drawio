        <mxCell id="dD1uLhPECOwK_6Fe8-Jx-16" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Comic Sans MS;fontStyle=1" value="&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;u&gt;CORE ENTITIES&lt;br&gt;&lt;/u&gt;&lt;/font&gt;&lt;div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;1. Label: Region, node, host&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;span&gt;2. Metric: values against timestamps cpu_usage{host=&quot;server_1&quot;, region=&quot;US-east&quot;} = 0.75&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;span&gt;3. Series: Unique combination of metric(value,timestamp)and labels.&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;font&gt;&lt;span&gt;4.&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; text-align: center;&quot;&gt;&lt;font&gt;&lt;span&gt;Alert Rule&lt;/span&gt;&lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;font style=&quot;&quot;&gt;&lt;span&gt;5.&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;span style=&quot;background-color: transparent; text-align: center;&quot;&gt;&lt;font style=&quot;&quot;&gt;Dashboard&lt;/font&gt;&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="150" width="740" x="-620" y="665" as="geometry" />
        </mxCell>
        <mxCell id="dD1uLhPECOwK_6Fe8-Jx-17" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontFamily=Comic Sans MS;fontStyle=1" value="&lt;font style=&quot;font-size: 21px;&quot;&gt;&lt;u&gt;ThroughPut&lt;/u&gt;&lt;/font&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;font style=&quot;font-size: 16px;&quot;&gt;1 server -&amp;gt; 100 metrics per 10Sec = 10/sec&lt;br&gt;&lt;/font&gt;&lt;span style=&quot;font-size: 16px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;500K Servers -&amp;gt; 500k * 10= 5Mil/sec&lt;br&gt;&lt;br&gt;&lt;br&gt;Storage&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 16px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;1 Metric = 100-200 bytes&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;font-size: 16px; background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;5Mil metrics = 5 * 2* 10^6 * 10^2 = 1Gbps&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="380" x="-260" y="838.75" as="geometry" />
        </mxCell>
